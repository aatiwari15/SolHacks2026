# This is the example structure of what your .env file should look like.
#
# DO NOT MODIFY this file - this is published as part of your Git repository.
# Instead, create a new file at the root of your project called `.env`, paste
# the contents of this file into `.env`, and change the environment variables
# to match configuration from Supabase.
#
# Note that environment variables prefixed by `NEXT_PUBLIC_` are ultimately
# shipped as part of the client application JS bundle the browser recieves.
# Since `DATABASE_URL` does not have this prefix, this environment variable is
# only accessible by the server. Attempting to access its value from the client
# side will result in an error, protecting our sensitive database URL.

DATABASE_URL=DATABASE_URL_HERE
NEXT_PUBLIC_SUPABASE_URL=SUPABASE_URL_HERE
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=SUPABASE_PUBLISHABLE_KEY_HERE
SUPABASE_SERVICE_ROLE_KEY=SUPABASE_SERVICE_ROLE_KEY_HERE

# ElevenLabs
ELEVENLABS_API_KEY=ELEVENLABS_API_KEY_HERE
NEXT_PUBLIC_ELEVENLABS_AGENT_ID=ELEVENLABS_AGENT_ID_HERE

# Gemini
GEMINI_API_KEY=GEMINI_API_KEY_HERE

# IBM watsonx Orchestrate
IBMWATSONX_API_KEY=IBMWATSONX_API_KEY_HERE
IBMWATSONX_INSTANCE_ID=IBMWATSONX_INSTANCE_ID_HERE
IBMWATSONX_BASE_URL=https://us-south.ml.cloud.ibm.com/ml/v1
# Specific agent endpoint for the interactive call feature (Dante/Habla/Simpli)
IBM_ORCHESTRATE_AGENT_URL=IBM_ORCHESTRATE_AGENT_URL_HERE
IBM_ORCHESTRATE_API_KEY=IBM_ORCHESTRATE_API_KEY_HERE
IBM_ORCHESTRATE_AGENT_ID=IBM_ORCHESTRATE_AGENT_ID_HERE

# Twilio — interactive voice calls
TWILIO_ACCOUNT_SID=TWILIO_ACCOUNT_SID_HERE
TWILIO_AUTH_TOKEN=TWILIO_AUTH_TOKEN_HERE
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
# Public base URL that Twilio can reach for webhooks (e.g. https://your-ngrok.ngrok-free.app)
TWILIO_WEBHOOK_BASE_URL=TWILIO_WEBHOOK_BASE_URL_HERE

# LiveKit
LIVEKIT_URL=wss://your-livekit-instance.livekit.cloud
LIVEKIT_API_KEY=LIVEKIT_API_KEY_HERE
LIVEKIT_API_SECRET=LIVEKIT_API_SECRET_HERE

# Internal — shared secret for the Selenium → /api/broadcast relay
BROADCAST_SECRET=SOME_RANDOM_SECRET_HERE
